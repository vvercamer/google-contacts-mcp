# Copy to .env (gitignored) and fill in your own values.
# Loaded automatically by start-guardrail.sh.

# Absolute path to the Markdown sync journal (append-only). Required to enable journaling.
# Quote the value if the path contains spaces.
VAULT_JOURNAL_PATH="/absolute/path/to/your/sync-journal.md"

# Optional overrides
# DRY_RUN=1
# PORT=3000
